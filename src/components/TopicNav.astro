---
// Topic selector: the upper block of the sidebar. Each Topic is a top-level
// vault section; clicking one swaps the file tree below (client-side only,
// no navigation — see scripts/topic.ts). The active Topic is rendered
// server-side from the current doc's section.
interface Props {
  sections: string[];
  active: string;
}
const { sections, active } = Astro.props;

// Inner SVG markup per known section, with a folder fallback. Stroke icons,
// 24x24 viewBox — colour comes from currentColor.
const ICONS: Record<string, string> = {
  rules:
    '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  agents:
    '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/>',
  skills: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  docs:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>',
  root:
    '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
};
const FALLBACK =
  '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>';
const iconFor = (s: string) => ICONS[s] ?? FALLBACK;
const labelFor = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---
<nav class="topic-nav" aria-label="Topics">
  <ul>
    {sections.map((s) => (
      <li>
        <button
          type="button"
          class={`topic ${s === active ? 'active' : ''}`}
          data-topic={s}
          aria-selected={s === active ? 'true' : 'false'}
        >
          <svg class="topic-ic" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconFor(s)} />
          <span class="topic-label">{labelFor(s)}</span>
        </button>
      </li>
    ))}
  </ul>
</nav>
