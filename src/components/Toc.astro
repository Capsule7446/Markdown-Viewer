---
import type { TocEntry } from '../lib/vault';

interface Props {
  toc: TocEntry[];
}
const { toc } = Astro.props;
---
<aside class="toc">
  <div class="toc-head">
    <span class="toc-title">On this page</span>
  </div>
  <ul>
    {toc.map((h) => (
      <li class={`lvl-${h.level}`}>
        <a href={`#${h.id}`} data-id={h.id}>{h.text}</a>
        <button class="toc-copy" type="button" data-anchor={h.id} title="複製此段落連結" aria-label="複製此段落連結">
          <svg class="ic-copy" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg class="ic-ok" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </li>
    ))}
  </ul>
</aside>
